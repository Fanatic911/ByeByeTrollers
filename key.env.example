# Copy this file to "key.env" and fill in real values.
# NEVER commit key.env to git - it is already listed in .gitignore.

DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY
RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_SECRET_KEY
WEBHOOK_SUCCESS_VERIFY=https://discord.com/api/webhooks/xxx/yyy
WEBHOOK_ERROR_VERIFY=https://discord.com/api/webhooks/xxx/yyy
WEBHOOK_LOGS=https://discord.com/api/webhooks/xxx/yyy

# JWT_SECRET: any random string, 32+ characters.
JWT_SECRET=REPLACE_WITH_32_PLUS_RANDOM_CHARACTERS

# ENCRYPTION_KEY: must be EXACTLY 64 hex characters (32 bytes).
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARACTERS

NODE_ENV=production
PORT=3001
HOST=127.0.0.1
ALLOWED_DOMAINS=localhost,127.0.0.1
